# 统一网关配置
# 复制此文件为 .env 并填写对应 provider 的值

# ==================== 必填：选择 Provider ====================
# 可选值: deepseek, kimi, mimo, minimax, auto
#
# 单 provider 模式（推荐）：
#   deepseek — 需要 DEEPSEEK_API_KEY
#   kimi     — 需要 KIMI_API_KEY，内部按 key 前缀细分 codingplan/PAYG
#   mimo     — 需要 MIMO_API_KEY，内部按 key 前缀细分 PAYG/Token Plan
#   minimax  — 需要 MINIMAX_API_KEY，内部按 key 前缀细分 PAYG/Coding Plan
#
# 自动路由模式（一个网关服务多个 provider）：
#   auto — 根据 incoming key 前缀自动选择 provider：
#     dk-*       → DeepSeek（网关约定前缀）
#     sk-kimi-*  → Kimi codingplan
#     sk-mimo-*  → MiMo PAYG（明确前缀，无歧义）
#     tp-*       → MiMo Token Plan
#     sk-*       → MiMo PAYG（默认，最常见）
#     注意：当前 auto 模式不自动识别 MiniMax（保持现网行为不变）
#
#   注意：auto 模式下若设置了某 provider 的 API key 环境变量，
#   所有流量将被锁定到该 provider（启动时会有告警日志）。
ACTIVE_PROVIDER=deepseek

# ==================== 通用配置 ====================
GATEWAY_PORT=7890
ALLOWED_ORIGIN=https://pivot.claude.ai
# Word/Office client access token. Keep this different from every upstream API key.
GATEWAY_ACCESS_TOKEN=
# Public HTTPS entry used by the switcher for "test public gateway" and Office manifest examples.
OFFICE_AI_PUBLIC_URL=https://word.example.com
DEFAULT_MAX_TOKENS=4096
MIN_COMPAT_MAX_TOKENS=16

# ==================== 实验能力开关 ====================
# Web Search server tool 透传开关：
#   false: 过滤 web_search server tool 相关结构（默认，兼容历史行为）
#   true : 允许并透传 web_search_* / server_tool_use / web_search_tool_result
ENABLE_WEB_SEARCH_TOOL=false
# 非流式 tool_use 自动执行开关（网关本地执行 web_search 后自动二轮补 tool_result）：
#   true : 自动执行（默认）
#   false: 仅透传 tool_use，由客户端自行执行工具回路
ENABLE_AUTO_WEB_SEARCH_EXECUTION=true
# 说明：当该开关为 true 时，网关会把 web_search_* 强制改写为 client tool（统一协议），
# 并在补完首轮 tool_result 后对后续轮次强制 tool_choice=none 防止继续 tool_use。
# 自动搜索返回条数（每次 tool_use）
AUTO_WEB_SEARCH_MAX_RESULTS=5
# 自动搜索超时时间（秒）
AUTO_WEB_SEARCH_TIMEOUT_SECONDS=20
# 自动工具回路最大轮数（1 表示只补一轮；建议 2~3）
AUTO_WEB_SEARCH_MAX_ROUNDS=2

# ==================== Claude 别名（所有 provider 共用） ====================
# Excel 插件发送的模型名 → 网关识别的别名
# 主名：简洁名（sonnet/opus）
# 兼容名：带 claude- 前缀的长名（claude-sonnet-4-5 等）
ALIAS_OPUS=opus
ALIAS_OPUS_VERSIONED=claude-opus-4-5
ALIAS_SONNET=sonnet
ALIAS_SONNET_VERSIONED=claude-sonnet-4-5
# 历史兼容（建议保留默认，避免旧缓存请求报错；网关内部会映射到 Sonnet 档）
ALIAS_HAIKU=haiku
ALIAS_HAIKU_VERSIONED=claude-haiku-4-5

# ==================== 模型映射（三档） ====================
#   Opus   → model_primary（pro 级）
#   Sonnet → model_mid（标准级）
#   Haiku  → 兼容映射到 Sonnet 档（不再单独暴露）
#
# 各 provider 默认模型：
#   DeepSeek: primary=deepseek-v4-pro,   mid=deepseek-v4-flash,  fast=deepseek-v4-flash
#   Kimi:     primary=kimi-k2.6,         mid=kimi-k2.5,          fast=kimi-k2.5,          codingplan=kimi-for-coding
#   MiMo:     primary=mimo-v2.5-pro,     mid=mimo-v2.5,          fast=mimo-v2.5
#   MiniMax:  primary=MiniMax-M2.7,      mid=MiniMax-M2.5,       fast=MiniMax-M2.5-highspeed
#
# 全局默认值（被 provider 维度变量覆盖）：
MODEL_PRIMARY=deepseek-v4-pro
MODEL_MID=deepseek-v4-flash
MODEL_FAST=deepseek-v4-flash
# 若需每个 provider 使用不同模型，取消注释以下 provider 维度变量（优先级更高）：
# DEEPSEEK_MODEL_PRIMARY=deepseek-v4-pro
# DEEPSEEK_MODEL_MID=deepseek-v4-flash
# DEEPSEEK_MODEL_FAST=deepseek-v4-flash
# KIMI_MODEL_PRIMARY=kimi-k2.6
# KIMI_MODEL_MID=kimi-k2.5
# KIMI_MODEL_FAST=kimi-k2.5
# MIMO_MODEL_PRIMARY=mimo-v2.5-pro
# MIMO_MODEL_MID=mimo-v2.5
# MIMO_MODEL_FAST=mimo-v2.5
# MINIMAX_MODEL_PRIMARY=MiniMax-M2.7
# MINIMAX_MODEL_MID=MiniMax-M2.5
# MINIMAX_MODEL_FAST=MiniMax-M2.5-highspeed

# ==================== DeepSeek 配置 ====================
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/anthropic

# ==================== Kimi 配置 ====================
# 路由规则:
#   sk-kimi-* token -> codingplan 路由 (KIMI_CODING_BASE_URL)
#   其他 sk-* token -> PAYG 路由 (KIMI_PAYG_BASE_URL)
KIMI_API_KEY=
KIMI_PAYG_BASE_URL=https://api.moonshot.cn/anthropic
KIMI_CODING_BASE_URL=https://api.kimi.com/coding/
CODINGPLAN_MODEL=kimi-for-coding

# ==================== MiMo 配置 ====================
# 计费模式:
#   sk-* key -> PAYG 模式
#   tp-* key -> Token Plan 模式（按区域路由）
MIMO_API_KEY=
MIMO_PAYG_BASE_URL=https://api.xiaomimimo.com/anthropic
MIMO_TP_REGION=cn
MIMO_TP_BASE_URL_CN=https://token-plan-cn.xiaomimimo.com/anthropic
MIMO_TP_BASE_URL_SGP=https://token-plan-sgp.xiaomimimo.com/anthropic
MIMO_TP_BASE_URL_AMS=https://token-plan-ams.xiaomimimo.com/anthropic

# ==================== MiniMax 配置 ====================
# 计费模式:
#   sk-api-* key -> PAYG
#   sk-cp-*  key -> Coding Plan / Token Plan
# 区域:
#   MINIMAX_REGION=cn|global（默认 cn）
#   请求头可覆盖 x-minimax-region=cn|global
MINIMAX_API_KEY=
MINIMAX_REGION=cn
MINIMAX_BASE_URL_CN=https://api.minimaxi.com/anthropic
MINIMAX_BASE_URL_GLOBAL=https://api.minimax.io/anthropic

# ==================== 日志配置 ====================
# 日志内容脱敏（默认开启，生产环境建议保持开启）
LOG_CONTENT_REDACT=true
# 日志中单个文本块最大显示字符数
LOG_CONTENT_MAX_CHARS=200
# 请求体日志最大字节数
LOG_BODY_LIMIT_BYTES=65536
# 请求体预览最大字符数
LOG_BODY_PREVIEW_CHARS=2500
